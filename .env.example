# Este é um arquivo de exemplo. Copie-o para .env e preencha as variáveis.
# Não comite o arquivo .env no seu repositório Git.

# Docker Compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=totem_db

# Banco e Filas
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/totem_db"
REDIS_URL="redis://localhost:6379"

# Storage (MinIO local)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=totem-media

# Auth (Dashboard)
# Gere um segredo forte com: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3000"

# API
API_URL="http://localhost:8787" # Porta padrão do Hono/Wrangler
JWT_DEVICE_SECRET= # Gere um segredo forte com: openssl rand -base64 32